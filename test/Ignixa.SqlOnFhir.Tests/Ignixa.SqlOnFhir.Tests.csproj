<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Core/Ignixa.SqlOnFhir/Ignixa.SqlOnFhir.csproj" />
    <ProjectReference Include="../../src/Core/Ignixa.FhirPath/Ignixa.FhirPath.csproj" />
    <ProjectReference Include="../../src/Core/Ignixa.Specification/Ignixa.Specification.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="sql-on-fhir-tests\**\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>sql-on-fhir-tests\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>

</Project>

{
  "resourceType": "TestScript",
  "name": "Bundles/transaction",
  "description": "Bundle transaction conformance tests. POSTs a type=transaction Bundle to the FHIR base URL. The engine has no dedicated transaction operation code — type.code='transaction' is unrecognised by DeriveMethod and falls through to POST, and with no url/resource/params the request URL resolves to the empty relative path (the server base), which is exactly the transaction endpoint. The Bundle bodies are static fixtures (server-assigned IDs) so no client IDs are needed. Idempotency is exercised via request.ifNoneExist (conditional create).",
  "status": "active",
  "fixture": [
    {
      "id": "tx-bundle",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Bundle",
        "type": "transaction",
        "entry": [
          {
            "resource": {
              "resourceType": "Patient",
              "identifier": [{ "system": "http://fhir262/bundle-tx", "value": "BTX-1" }],
              "name": [{ "family": "Bundle", "given": ["Alpha"] }]
            },
            "request": { "method": "POST", "url": "Patient" }
          },
          {
            "resource": {
              "resourceType": "Patient",
              "identifier": [{ "system": "http://fhir262/bundle-tx", "value": "BTX-2" }],
              "name": [{ "family": "Bundle", "given": ["Beta"] }]
            },
            "request": { "method": "POST", "url": "Patient" }
          },
          {
            "resource": {
              "resourceType": "Patient",
              "identifier": [{ "system": "http://fhir262/bundle-tx", "value": "BTX-3" }],
              "name": [{ "family": "Bundle", "given": ["Gamma"] }]
            },
            "request": { "method": "POST", "url": "Patient" }
          }
        ]
      }
    },
    {
      "id": "tx-conditional-bundle",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Bundle",
        "type": "transaction",
        "entry": [
          {
            "resource": {
              "resourceType": "Patient",
              "identifier": [{ "system": "http://fhir262/bundle-tx", "value": "BTX-1" }],
              "name": [{ "family": "Bundle", "given": ["Alpha"] }]
            },
            "request": {
              "method": "POST",
              "url": "Patient",
              "ifNoneExist": "identifier=http://fhir262/bundle-tx|BTX-1"
            }
          }
        ]
      }
    }
  ],
  "test": [
    {
      "name": "Transaction creates resources",
      "description": "POST a transaction Bundle of 3 Patient creates to the base URL. The server must return 200 with a transaction-response Bundle of 3 entries, each with a 2xx response.status.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "transaction" }, "method": "POST", "sourceId": "tx-bundle", "responseId": "tx-response", "description": "POST transaction Bundle (3 Patient creates) to the base URL" } },
        { "assert": { "description": "Transaction must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Response Bundle must be of type transaction-response", "expression": "type = 'transaction-response'" } },
        { "assert": { "description": "Response must contain 3 entries", "expression": "entry.count() = 3" } },
        { "assert": { "description": "Every entry must report a 2xx response status", "expression": "entry.all(response.status.startsWith('2'))" } }
      ]
    },
    {
      "name": "Resources are retrievable after transaction",
      "description": "After the transaction commits, a search by one of the bundle identifiers must return at least one match, proving the resources were persisted.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?identifier=http://fhir262/bundle-tx|BTX-1", "responseId": "tx-search", "description": "GET /Patient?identifier=http://fhir262/bundle-tx|BTX-1" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "At least one BTX-1 Patient must be found", "expression": "entry.count() >= 1" } }
      ]
    },
    {
      "name": "Conditional create (If-None-Exist) is idempotent",
      "description": "POST a transaction Bundle containing one Patient create guarded by ifNoneExist for an identifier that already exists (BTX-1). The transaction must succeed (200) and the entry must report status 200 (matched existing, not re-created 201).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "transaction" }, "method": "POST", "sourceId": "tx-conditional-bundle", "responseId": "tx-cond-response", "description": "POST transaction Bundle with ifNoneExist for the already-existing BTX-1" } },
        { "assert": { "description": "Conditional transaction must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "The single entry must report status 200 (existing resource matched, not created)", "expression": "entry[0].response.status.startsWith('200')", "warningOnly": true } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "Patient?identifier=http://fhir262/bundle-tx|BTX-1", "description": "Teardown: conditional delete BTX-1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient?identifier=http://fhir262/bundle-tx|BTX-2", "description": "Teardown: conditional delete BTX-2" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient?identifier=http://fhir262/bundle-tx|BTX-3", "description": "Teardown: conditional delete BTX-3" } }
    ]
  }
}

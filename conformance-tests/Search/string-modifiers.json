  "test": [
    {
      "name": "exact: family:exact=Smith matches full string case-sensitively",
      "description": "GET /Patient?family:exact=Smith must return only the patient whose family name is exactly 'Smith' (case-sensitive, whole-string). Prefix matches (Smithson) and case-mismatches (smith) must be excluded.",
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?family:exact=Smith&identifier=http://fhir262/test|&_count=100", "responseId": "exact-smith-response", "description": "Search family:exact=Smith" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include patient-exact-smith (exact 'Smith')", "expression": "entry.where(resource.id = '${patientExactSmithId}').exists()" } },
        { "assert": { "description": "Must NOT include patient-exact-smithson (prefix, not exact)", "expression": "entry.where(resource.id = '${patientExactSmithsonId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include patient-exact-smith-lower (wrong case)", "expression": "entry.where(resource.id = '${patientExactSmithLowerId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "exact: family:exact=smith matches only lowercase",
      "description": "GET /Patient?family:exact=smith must match only the lowercase 'smith' family name; the capitalized variants are case-sensitive misses.",
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?family:exact=smith&identifier=http://fhir262/test|&_count=100", "responseId": "exact-smith-lower-response", "description": "Search family:exact=smith" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include patient-exact-smith-lower (exact lowercase 'smith')", "expression": "entry.where(resource.id = '${patientExactSmithLowerId}').exists()" } },
        { "assert": { "description": "Must NOT include patient-exact-smith (wrong case)", "expression": "entry.where(resource.id = '${patientExactSmithId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include patient-exact-smithson", "expression": "entry.where(resource.id = '${patientExactSmithsonId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "contains: family:contains=son matches substring anywhere",
      "description": "GET /Patient?family:contains=son must match any family name containing 'son' as a substring (Anderson, Sonder, Samsonite), and exclude Brown.",
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?family:contains=son&identifier=http://fhir262/test|&_count=100", "responseId": "contains-son-response", "description": "Search family:contains=son" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include patient-ct-anderson", "expression": "entry.where(resource.id = '${patientCtAndersonId}').exists()" } },
        { "assert": { "description": "Must include patient-ct-sonder", "expression": "entry.where(resource.id = '${patientCtSonderId}').exists()" } },
        { "assert": { "description": "Must include patient-ct-samsonite", "expression": "entry.where(resource.id = '${patientCtSamsoniteId}').exists()" } },
        { "assert": { "description": "Must NOT include patient-ct-brown", "expression": "entry.where(resource.id = '${patientCtBrownId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "contains: family:contains=SON is case-insensitive",
      "description": "GET /Patient?family:contains=SON must behave case-insensitively, matching the same set as lowercase 'son'.",
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?family:contains=SON&identifier=http://fhir262/test|&_count=100", "responseId": "contains-son-upper-response", "description": "Search family:contains=SON" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include patient-ct-anderson", "expression": "entry.where(resource.id = '${patientCtAndersonId}').exists()" } },
        { "assert": { "description": "Must include patient-ct-sonder", "expression": "entry.where(resource.id = '${patientCtSonderId}').exists()" } },
        { "assert": { "description": "Must include patient-ct-samsonite", "expression": "entry.where(resource.id = '${patientCtSamsoniteId}').exists()" } },
        { "assert": { "description": "Must NOT include patient-ct-brown", "expression": "entry.where(resource.id = '${patientCtBrownId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "contains: url:contains=acme matches ValueSet URL substring",
      "description": "GET /ValueSet?url:contains=acme must match the ValueSet whose url contains 'acme' and exclude the example.org one.",
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "ValueSet", "params": "?url:contains=acme&identifier=http://fhir262/test|&_count=100", "responseId": "contains-acme-response", "description": "Search ValueSet url:contains=acme" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include valueset-ct-acme", "expression": "entry.where(resource.id = '${valuesetCtAcmeId}').exists()" } },
        { "assert": { "description": "Must NOT include valueset-ct-example", "expression": "entry.where(resource.id = '${valuesetCtExampleId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },

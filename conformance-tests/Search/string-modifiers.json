    {
      "name": "not: gender:not=male excludes male and includes no-gender",
      "description": "GET /Patient?gender:not=male must return patients whose gender is not male (female, other) plus those with no gender, while excluding male patients.",
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?gender:not=male&identifier=http://fhir262/test|&_count=100", "responseId": "gender-not-male-response", "description": "Search gender:not=male" } },

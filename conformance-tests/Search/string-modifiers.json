        { "assert": { "description": "Must include patient-mi-full (has gender)", "expression": "entry.where(resource.id = '${patientMiFullId}').exists()" } },
        { "assert": { "description": "Must NOT include patient-mi-empty (no gender)", "expression": "entry.where(resource.id = '${patientMiEmptyId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "missing: birthdate:missing=true returns records without birthDate",
      "description": "GET /Patient?birthdate:missing=true must return patients with no birthDate element.",
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?birthdate:missing=true&identifier=http://fhir262/test|&_count=100", "responseId": "birthdate-missing-true-response", "description": "Search birthdate:missing=true" } },

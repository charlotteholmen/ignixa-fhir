{
  "resourceType": "TestScript",
  "name": "Search/chaining",
  "description": "Forward chaining, _has reverse chaining, and compartment search conformance tests. Uses client-supplied IDs (PUT) for all fixtures so cross-references (managingOrganization, subject) resolve statically — servers that reject client-assigned IDs will fail setup, a known limitation of the TestScript format for cross-resource tests. Org fhir262-chain-org (ACME Corp); Patient fhir262-chain-pa (Smith, has org) and fhir262-chain-pb (Jones, no org); Observations obs1 (heart rate 8867-4) and obs2 (body weight 29463-7) both on pa.",
  "status": "active",
  "fixture": [
    {
      "id": "org-acme",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Organization",
        "id": "fhir262-chain-org",
        "identifier": [{ "system": "http://fhir262/test", "value": "CHAIN-ORG1" }],
        "name": "ACME Corp"
      }
    },
    {
      "id": "patient-pa",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-chain-pa",
        "identifier": [{ "system": "http://fhir262/test", "value": "JOIN-PA" }],
        "name": [{ "family": "Smith", "given": ["Alex"] }],
        "managingOrganization": { "reference": "Organization/fhir262-chain-org" }
      }
    },
    {
      "id": "patient-pb",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-chain-pb",
        "identifier": [{ "system": "http://fhir262/test", "value": "JOIN-PB" }],
        "name": [{ "family": "Jones", "given": ["Bob"] }]
      }
    },
    {
      "id": "obs-1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Observation",
        "id": "fhir262-chain-obs1",
        "identifier": [ { "system": "http://fhir262/test", "value": "CHAIN-OBS1" } ],
        "status": "final",
        "code": {
          "coding": [{ "system": "http://loinc.org", "code": "8867-4", "display": "Heart rate" }]
        },
        "subject": { "reference": "Patient/fhir262-chain-pa" },
        "valueQuantity": { "value": 72, "unit": "beats/minute", "system": "http://unitsofmeasure.org", "code": "/min" }
      }
    },
    {
      "id": "obs-2",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Observation",
        "id": "fhir262-chain-obs2",
        "identifier": [ { "system": "http://fhir262/test", "value": "CHAIN-OBS2" } ],
        "status": "final",
        "code": {
          "coding": [{ "system": "http://loinc.org", "code": "29463-7", "display": "Body weight" }]
        },
        "subject": { "reference": "Patient/fhir262-chain-pa" },
        "valueQuantity": { "value": 70, "unit": "kg", "system": "http://unitsofmeasure.org", "code": "kg" }
      }
    }
  ],
  "setup": {
    "action": [
      { "operation": { "type": { "code": "update" }, "url": "Organization/fhir262-chain-org", "sourceId": "org-acme", "description": "PUT Organization/fhir262-chain-org (ACME Corp) — client-supplied ID so Patient can reference it" } },
      { "operation": { "type": { "code": "update" }, "url": "Patient/fhir262-chain-pa", "sourceId": "patient-pa", "description": "PUT Patient/fhir262-chain-pa (Smith, managingOrganization=ACME)" } },
      { "operation": { "type": { "code": "update" }, "url": "Patient/fhir262-chain-pb", "sourceId": "patient-pb", "description": "PUT Patient/fhir262-chain-pb (Jones, no managingOrganization)" } },
      { "operation": { "type": { "code": "update" }, "url": "Observation/fhir262-chain-obs1", "sourceId": "obs-1", "description": "PUT Observation/fhir262-chain-obs1 (heart rate 8867-4, subject=pa)" } },
      { "operation": { "type": { "code": "update" }, "url": "Observation/fhir262-chain-obs2", "sourceId": "obs-2", "description": "PUT Observation/fhir262-chain-obs2 (body weight 29463-7, subject=pa)" } }
    ]
  },
  "test": [
    {
      "name": "Forward chain: organization.name",
      "description": "Patient?organization.name=ACME Corp follows the managingOrganization reference to the Organization and matches on its name. fhir262-chain-pa (org=ACME) must match; fhir262-chain-pb (no managingOrganization) must not.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?organization.name=ACME%20Corp", "responseId": "fwd-org-name", "description": "GET /Patient?organization.name=ACME Corp" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include fhir262-chain-pa (managingOrganization=ACME Corp)", "expression": "entry.where(resource.id = 'fhir262-chain-pa').exists()" } },
        { "assert": { "description": "Must NOT include fhir262-chain-pb (no managingOrganization)", "expression": "entry.where(resource.id = 'fhir262-chain-pb').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Forward chain with type modifier: subject:Patient.family",
      "description": "Observation?subject:Patient.family=Smith follows subject to a Patient and matches on family name. Both obs1 and obs2 belong to fhir262-chain-pa (family=Smith) and must match.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?subject:Patient.family=Smith&identifier=http://fhir262/test|&_count=100", "responseId": "fwd-subject-family", "description": "GET /Observation?subject:Patient.family=Smith" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs1 (subject=pa, family Smith)", "expression": "entry.where(resource.id = 'fhir262-chain-obs1').exists()" } },
        { "assert": { "description": "Must include obs2 (subject=pa, family Smith)", "expression": "entry.where(resource.id = 'fhir262-chain-obs2').exists()" } }
      ]
    },
    {
      "name": "_has reverse chain: patients with a heart rate observation",
      "description": "Patient?_has:Observation:subject:code=8867-4 returns patients that are the subject of an Observation with code 8867-4. fhir262-chain-pa (has obs1) must match; fhir262-chain-pb (no observations) must not.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_has:Observation:subject:code=8867-4", "responseId": "has-heartrate", "description": "GET /Patient?_has:Observation:subject:code=8867-4" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include fhir262-chain-pa (subject of heart rate obs1)", "expression": "entry.where(resource.id = 'fhir262-chain-pa').exists()" } },
        { "assert": { "description": "Must NOT include fhir262-chain-pb (has no observations)", "expression": "entry.where(resource.id = 'fhir262-chain-pb').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "_has reverse chain: patients with a body weight observation",
      "description": "Patient?_has:Observation:subject:code=29463-7 returns patients that are the subject of an Observation with code 29463-7. fhir262-chain-pa (has obs2) must match; fhir262-chain-pb must not.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_has:Observation:subject:code=29463-7", "responseId": "has-weight", "description": "GET /Patient?_has:Observation:subject:code=29463-7" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include fhir262-chain-pa (subject of body weight obs2)", "expression": "entry.where(resource.id = 'fhir262-chain-pa').exists()" } },
        { "assert": { "description": "Must NOT include fhir262-chain-pb (has no observations)", "expression": "entry.where(resource.id = 'fhir262-chain-pb').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Compartment search: Patient observations",
      "description": "GET /Patient/fhir262-chain-pa/Observation returns the Observation compartment for the patient. Uses the url field directly (no resource field) so the engine sends the compartment path verbatim. Both obs1 and obs2 must appear.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "url": "Patient/fhir262-chain-pa/Observation", "responseId": "compartment-obs", "description": "GET /Patient/fhir262-chain-pa/Observation (compartment search)" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Compartment must contain at least 2 observations", "expression": "entry.count() >= 2" } },
        { "assert": { "description": "Must include obs1 (heart rate)", "expression": "entry.where(resource.id = 'fhir262-chain-obs1').exists()" } },
        { "assert": { "description": "Must include obs2 (body weight)", "expression": "entry.where(resource.id = 'fhir262-chain-obs2').exists()" } }
      ]
    },
    {
      "name": "GET/POST search equivalence for _has",
      "description": "The same _has search via GET and POST _search must return identical results. Tests that servers correctly handle application/x-www-form-urlencoded _search bodies.",
      "extension": [
        { "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }
      ],
      "action": [
        {
          "operation": {
            "type": { "code": "search" },
            "resource": "Patient",
            "params": "?_has:Observation:subject:code=8867-4",
            "responseId": "get-has-response",
            "description": "GET Patient?_has:Observation:subject:code=8867-4"
          }
        },
        { "assert": { "description": "GET: HTTP 200", "response": "okay" } },
        { "assert": { "description": "GET: returns a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "GET: must include fhir262-chain-pa", "expression": "entry.where(resource.id = 'fhir262-chain-pa').exists()" } },
        { "assert": { "description": "GET: must NOT include fhir262-chain-pb", "expression": "entry.where(resource.id = 'fhir262-chain-pb').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        {
          "operation": {
            "type": { "code": "search" },
            "resource": "Patient",
            "params": "?_has:Observation:subject:code=8867-4",
            "method": "POST",
            "responseId": "post-has-response",
            "description": "POST Patient/_search with same params as form body"
          }
        },
        { "assert": { "description": "POST: HTTP 200", "response": "okay", "sourceId": "post-has-response" } },
        { "assert": { "description": "POST: returns a Bundle", "resource": "Bundle", "sourceId": "post-has-response" } },
        { "assert": { "description": "POST: must include fhir262-chain-pa", "expression": "entry.where(resource.id = 'fhir262-chain-pa').exists()", "sourceId": "post-has-response" } },
        { "assert": { "description": "POST: must NOT include fhir262-chain-pb", "expression": "entry.where(resource.id = 'fhir262-chain-pb').exists()", "value": "false", "operator": "equals", "warningOnly": true, "sourceId": "post-has-response" } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "Observation/fhir262-chain-obs1", "description": "Teardown: delete obs1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/fhir262-chain-obs2", "description": "Teardown: delete obs2" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/fhir262-chain-pa", "description": "Teardown: delete patient pa" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/fhir262-chain-pb", "description": "Teardown: delete patient pb" } },
      { "operation": { "type": { "code": "delete" }, "url": "Organization/fhir262-chain-org", "description": "Teardown: delete org" } }
    ]
  }
}

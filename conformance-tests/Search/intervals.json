      "description": "GET /Observation?code=fhir262-interval-test&date=eq${searchDate} must match only the Observation whose effective date falls within the requested period.",
      "extension": [{
        "url": "http://ignixa.io/testscript/parametrize",
        "extension": [
          { "url": "variable", "valueString": "searchDate" },
          { "url": "values", "valueString": "2028,2028-06,2028-06-15,2028-06-15T12:00:00Z" }
        ]
      }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code=fhir262-interval-test&date=eq${searchDate}", "responseId": "obs-eq-response", "description": "Search Observation date=eq${searchDate}" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-inside (2028-06-15)", "expression": "entry.where(resource.id = '${obsInsideId}').exists()" } },
        { "assert": { "description": "Must NOT include obs-past (2026)", "expression": "entry.where(resource.id = '${obsPastId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include obs-future (2030)", "expression": "entry.where(resource.id = '${obsFutureId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }

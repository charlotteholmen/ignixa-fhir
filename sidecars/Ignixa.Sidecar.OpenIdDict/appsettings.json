{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Grpc": "Information",
      "OpenIddict": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://*:5050",
        "Protocols": "Http2"
      },
      "Http": {
        "Url": "http://*:8080",
        "Protocols": "Http1"
      }
    }
  },
  "OpenIdDictAuthorization": {
    "RequiredScopes": [],
    "ActionScopeMapping": {
      "read": ["fhir.read", "fhir.*"],
      "write": ["fhir.write", "fhir.*"],
      "delete": ["fhir.delete", "fhir.*"],
      "search": ["fhir.read", "fhir.*"]
    },
    "AllowAuthenticatedByDefault": true
  }
}

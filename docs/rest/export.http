@hostname = https://127.0.0.1:7058
@tenantId = 1

###
# Bulk Export - System Level (All Resources)
# Starts an asynchronous export job for all resource types
# Returns: 202 Accepted with Content-Location header pointing to status endpoint
POST {{hostname}}/tenant/{{tenantId}}/$export
Prefer: respond-async

###
# Bulk Export - Specific Resource Types
# Export only Patient and Observation resources
# @name ExportRequest
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient,Observation
Prefer: respond-async

###
# Bulk Export - With Date Filter
# Export resources modified since a specific date
POST {{hostname}}/tenant/{{tenantId}}/$export?_since=2024-01-01T00:00:00Z
Prefer: respond-async

###
# Bulk Export - With Type Filters
# Export specific resources with search parameter filters
# Format: ResourceType?param=value
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Observation,Condition&_typeFilter=Observation?code=http://loinc.org|85354-9,Condition?category=encounter-diagnosis
Prefer: respond-async

###
# Bulk Export - Complete Example
# Export Patient and Observation resources since Jan 1, 2024 with filters
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient,Observation&_since=2024-01-01T00:00:00Z&_typeFilter=Observation?status=final&_outputFormat=application/fhir+ndjson
Prefer: respond-async

###
# Get Export Job Status
# Replace {jobId} with the actual job ID returned from the export request
# Returns: 202 Accepted (still processing) or 200 OK (complete with manifest)
GET {{hostname}}/tenant/{{tenantId}}/_export/{jobId}

###
# Get Export Job Status - Example with Job ID
# Replace the GUID with an actual job ID from your export request
GET {{hostname}}/tenant/{{tenantId}}/_export/12345678-1234-1234-1234-123456789abc

###
# Cancel Export Job
# Terminates a running export job
# Returns: 204 No Content
DELETE {{hostname}}/tenant/{{tenantId}}/_export/{jobId}

###
# Cancel Export Job - Example with Job ID
DELETE {{hostname}}/tenant/{{tenantId}}/_export/12345678-1234-1234-1234-123456789abc

###
# ============================================================================
# PARQUET EXPORT (Phase 1)
# ============================================================================

###
# Parquet Export - All Patients
# Exports Patient resources in Apache Parquet columnar format
# Output: .parquet files (3-5x smaller than NDJSON, optimized for analytics)
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient&_outputFormat=application/vnd.apache.parquet
Prefer: respond-async

###
# ============================================================================
# VIEWDEFINITION EXPORT (Phase 2 - SQL-on-FHIR)
# ============================================================================

###
# ViewDefinition Export - Patient Demographics
# Applies SQL-on-FHIR ViewDefinition to transform FHIR resources into tabular format
# Requires: ViewDefinition resource must exist in datastore (POST /ViewDefinition first)
# Output: Parquet files with columns defined by ViewDefinition
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient&_outputFormat=application/vnd.apache.parquet&_viewDefinition=patient-demographics
Prefer: respond-async

###
# ViewDefinition Export - Observation Vitals
# Export vital signs observations with specific columns (code, value, unit, date)
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Observation&_outputFormat=application/vnd.apache.parquet&_viewDefinition=observation-vitals
Prefer: respond-async

###
# Example: Create a ViewDefinition first
# POST a ViewDefinition resource before using it in export
POST {{hostname}}/ViewDefinition
Content-Type: application/fhir+json

{
  "resourceType": "ViewDefinition",
  "id": "patient-demographics",
  "name": "patient_demographics",
  "status": "active",
  "resource": "Patient",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "id",
          "type": "string"
        },
        {
          "name": "family_name",
          "path": "name.where(use='official').first().family",
          "type": "string"
        },
        {
          "name": "given_names",
          "path": "name.where(use='official').first().given.join(', ')",
          "type": "string"
        },
        {
          "name": "birth_date",
          "path": "birthDate",
          "type": "date"
        },
        {
          "name": "gender",
          "path": "gender",
          "type": "string"
        },
        {
          "name": "active",
          "path": "active",
          "type": "boolean"
        }
      ]
    }
  ]
}

###
# Parquet Export - Multiple Resource Types
# Export Patient and Observation resources as Parquet
# Each partition creates separate .parquet file
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient,Observation&_outputFormat=application/vnd.apache.parquet
Prefer: respond-async

###
# Parquet Export - With Date Filter
# Export resources modified since specific date in Parquet format
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient&_since=2024-01-01T00:00:00Z&_outputFormat=application/vnd.apache.parquet
Prefer: respond-async

###
# Parquet Export - Complete Example
# Export with filters and date range in Parquet format
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Observation&_since=2024-01-01T00:00:00Z&_typeFilter=Observation?status=final&_outputFormat=application/vnd.apache.parquet
Prefer: respond-async

###
# ============================================================================
# EXAMPLE WORKFLOWS
# ============================================================================

###
# Example: NDJSON Export Workflow
# 1. Start export (copy job ID from Content-Location header)
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient
Prefer: respond-async

# 2. Poll status (replace {jobId} with actual ID)
# GET {{hostname}}/tenant/{{tenantId}}/_export/{jobId}

# 3. Download files from URLs in the manifest when status is 200 OK
# The response will contain output URLs like:
# {
#   "transactionTime": "2025-01-08T12:00:00Z",
#   "request": "/tenant/1/$export",
#   "requiresAccessToken": false,
#   "output": [
#     {
#       "type": "Patient",
#       "url": "https://storage.example.com/tenant/1/export/{jobId}/Patient-1-1000.ndjson?sas_token"
#     }
#   ]
# }

###
# Example: Parquet Export Workflow
# 1. Start Parquet export
POST {{hostname}}/tenant/{{tenantId}}/$export?_type=Patient&_outputFormat=application/vnd.apache.parquet
Prefer: respond-async

# 2. Poll status until completion
# GET {{hostname}}/tenant/{{tenantId}}/_export/{jobId}

# 3. Download .parquet files and query with DuckDB:
#
# Example DuckDB queries (after downloading Patient-*.parquet files):
#
# -- Read single Parquet file
# SELECT * FROM read_parquet('Patient-1-1000.parquet') LIMIT 10;
#
# -- Read multiple Parquet files as one table (union)
# SELECT * FROM read_parquet('Patient-*.parquet') WHERE id = 'P123';
#
# -- Count resources per file
# SELECT filename, COUNT(*)
# FROM read_parquet('Patient-*.parquet', filename=true)
# GROUP BY filename;
#
# -- Extract specific columns only (columnar efficiency)
# SELECT id, resourceType
# FROM read_parquet('Patient-*.parquet');

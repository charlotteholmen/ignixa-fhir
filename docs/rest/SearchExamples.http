@hostname = https://localhost:7058

### Setup test data
# @name batch
POST {{hostname}}
Prefer: validation=minimum
Content-Type: application/json

< ./data/SearchDataBatch.json

### Batch2
POST {{hostname}}
Prefer: validation=minimum
Content-Type: application/json

{
    "resourceType": "Bundle",
    "type": "batch",
    "entry": [
        {
            "resource": {
                "resourceType": "Encounter",
                "id": "exampleencounter1",
                "status": "planned",
                "class": {
                    "system": "system",
                    "code": "code"
                },
                "subject": {
                    "reference": "Patient/searchpatientAA"
                }
            },
            "request": {
                "method": "PUT",
                "url": "Encounter/exampleencounter1"
            }
        }
    ]
}


### metadata
GET {{hostname}}/metadata

### Compartment Search All
GET {{hostname}}/Patient/example/*

### Sort Name
GET {{hostname}}/Patient?_sort=name&_total=accurate&_count=10000

### Sort Birthdate
GET {{hostname}}/Patient?_sort=birthdate

### Include
GET {{hostname}}/MedicationRequest?_include=MedicationRequest:patient&_count=1

###
POST {{hostname}}/Encounter
Prefer: validation=full
Content-Type: application/json

{
    "resourceType": "Encounter",
    "status": "planned",
    "class": {
        "system": "system",
        "code": "code"
    },
    "subject": {
        "reference": "Patient/searchpatient2"
    }
}

### Revinclude
GET {{hostname}}/Patient?_revinclude=Encounter:subject

### Elements
GET {{hostname}}/Patient?_elements=identifier,active

### Not modifier
GET {{hostname}}/Patient?gender:not=female

### Missing modifier
GET {{hostname}}/Patient?birthdate:missing=true

### Exact modifier
GET {{hostname}}/Patient?name:exact=Jon

### Contains modifier
GET {{hostname}}/Patient?address:contains=Meadow

### Chained search 1
GET {{hostname}}/DiagnosticReport?subject:Patient.name=Sarah&_count=1000&_total=accurate

### Chained search 2
GET {{hostname}}/Encounter?subject=Patient/searchpatient3

### Chained search 3
GET {{hostname}}/Encounter?subject:Patient.birthdate=1987-02-20

### Chained search 4
GET {{hostname}}/Patient?general-practitioner:Practitioner.name=Sarah&general-practitioner:Practitioner.address-state=WA

### Reverse chained search 1
GET {{hostname}}/Patient?_has:Observation:patient:code=527

### Reverse chained search 2
GET {{hostname}}/Patient?_has:Observation:patient:_has:AuditEvent:entity:agent:Practitioner.name=janedoe

### Composite search
GET {{hostname}}/DiagnosticReport?result.code-value-quantity=2823-3$lt9.2

### Get continuation token
# @name largeSearch
GET {{hostname}}/Patient?_count=2

### Record continuation token
@continuationToken = {{largeSearch.response.body.link[0].url}}

### Use continuation token
GET {{continuationToken}}

### Post search 1
POST {{hostname}}/Patient/_search?_id=searchpatient1

### Post search 2
POST {{hostname}}/Patient/_search
Content-Type: application/x-www-form-urlencoded

name=Jon

# The following queries and updates support testing _revinclude=*.*
# this still uses the SearchDataBatch.json above

### RevInclude=*.*
GET {{hostname}}/Patient?_id=searchpatient3&_revinclude=*:*

### Update Good Health Clinic
PUT {{hostname}}/Organization/good
Content-Type: application/json

{
  "resourceType": "Organization",
  "id": "good",
  "text": {
    "status": "generated",
    "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n      \n      <p>Good Health Clinic</p>\n    \n    </div>"
  },
  "identifier": [
    {
      "system": "urn:ietf:rfc:3986",
      "value": "2.16.840.1.113883.19.5"
    }
  ],
  "name": "Good Health Clinic"
}

### Update patient 3
PUT {{hostname}}/Patient/searchpatient3
Content-Type: application/json

{
  "resourceType": "Patient",
  "id": "searchpatient3",
  "meta": {
    "versionId": "1",
    "lastUpdated": "2023-11-07T18:23:18.037+00:00"
  },
  "active": true,
  "name": [
    {
      "family": "Chalmers",
      "given": [
        "jon"
      ]
    }
  ],
  "gender": "male",
  "birthDate": "1975-01-12",
  "address": [
    {
      "line": [
        "Dismal Drive"
      ]
    }
  ],
  "generalPractitioner": [
    {
      "reference": "Practitioner/searchpractitioner3"
    }
  ],
  "managingOrganization" :
  {
    "reference" : "Organization/good"
  }
}

###
PATCH {{hostname}}/Patient/searchpatient3
Content-Type: application/fhir+json

{
  "resourceType": "Parameters",
  "parameter": [
    {
      "name": "operation",
      "part": [
        {
          "name": "type",
          "valueCode": "replace"
        },
        {
          "name": "path",
          "valueString": "name[0].family"
        },
        {
          "name": "value",
          "valueString": "NewLastName"
        }
      ]
    }
  ]
}

###
PUT {{hostname}}/Observation
Content-Type: application/fhir+json

{
    "resourceType": "Observation",
    "text": {
        "status": "generated",
        "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p><b>Generated Narrative with Details</b></p></div>"
    },
    "status": "final",
    "category": [
        {
            "coding": [
                {
                    "system": "http://hl7.org/fhir/observation-category",
                    "code": "vital-signs",
                    "display": "Vital Signs"
                }
            ]
        }
    ],
    "code": {
        "coding": [
            {
                "system": "http://loinc.org",
                "code": "29463-7",
                "display": "Body Weight"
            },
            {
                "system": "http://loinc.org",
                "code": "3141-9",
                "display": "Body weight Measured"
            },
            {
                "system": "http://snomed.info/sct",
                "code": "27113001",
                "display": "Body weight"
            },
            {
                "system": "http://acme.org/devices/clinical-codes",
                "code": "body-weight",
                "display": "Body Weight"
            },
            {
                "system": "http://healthvault.com/vocabularies/vital-statistics",
                "code": "Wgt",
                "display": "Body Weight"
            }
        ]
    },
    "subject": {
        "reference": "Patient/example"
    },
    "effectiveDateTime": "2016-03-28",
    "valueQuantity": {
        "value": 67,
        "unit": "kg",
        "system": "http://unitsofmeasure.org",
        "code": "kg"
    }
}

### History

GET {{hostname}}/Observation/f8adc129-3d07-44fe-b505-9dd75bef6876/_history?_count=20

###

GET {{hostname}}/Observation
If-Match: _id=f8adc129-3d07-44fe-b505-9dd75bef6876

###

### Batch2
POST http://{{hostname}}
Prefer: validation=minimum
Content-Type: application/json

{
    "resourceType": "Bundle",
    "type": "batch",
    "entry": [
        {
            "resource": {
                "resourceType": "AuditEvent",
                "type": {
                    "system": "system",
                    "code": "code"
                },
                "recorded": "2021-05-28T00:00:00.000",
                "agent": [
                    {
                        "who": {
                            "reference": "Practitioner/searchpractitioner3"
                        }
                    }
                ],
                "source": {
                    "observer": {
                        "reference": "Patient/searchpatient2"
                    }
                },
                "entity": [
                    {
                        "what": {
                            "reference": "Observation/searchobservation2"
                        }
                    }
                ]
            },
            "request": {
                "method": "POST",
                "url": "AuditEvent"
            }
        }
    ]
}

### ============================
### $validate Operation Examples
### ============================

### Validate Patient - Direct Resource (Resource-level)
POST {{hostname}}/Patient/$validate
Content-Type: application/fhir+json

{
  "resourceType": "Patient",
  "id": "example-validate",
  "name": [
    {
      "use": "official",
      "family": "Doe",
      "given": ["John"]
    }
  ],
  "gender": "male",
  "birthDate": "1980-01-01"
}

### Validate Patient - Using Parameters Resource with mode
POST {{hostname}}/Patient/$validate
Content-Type: application/fhir+json

{
  "resourceType": "Parameters",
  "parameter": [
    {
      "name": "mode",
      "valueCode": "create"
    },
    {
      "name": "resource",
      "resource": {
        "resourceType": "Patient",
        "id": "123",
        "name": [
          {
            "family": "Smith",
            "given": ["Jane"]
          }
        ],
        "birthDate": "1990-05-15"
      }
    }
  ]
}

### Validate Patient - Using Parameters with profile
POST {{hostname}}/Patient/$validate
Content-Type: application/fhir+json

{
  "resourceType": "Parameters",
  "parameter": [
    {
      "name": "mode",
      "valueCode": "update"
    },
    {
      "name": "profile",
      "valueUri": "http://hl7.org/fhir/StructureDefinition/Patient"
    },
    {
      "name": "resource",
      "resource": {
        "resourceType": "Patient",
        "id": "validate-profile-test",
        "active": true,
        "name": [
          {
            "family": "Johnson",
            "given": ["Robert"]
          }
        ]
      }
    }
  ]
}

### Validate Observation - Direct Resource
POST {{hostname}}/Observation/$validate
Content-Type: application/fhir+json

{
  "resourceType": "Observation",
  "status": "final",
  "code": {
    "coding": [
      {
        "system": "http://loinc.org",
        "code": "29463-7",
        "display": "Body Weight"
      }
    ]
  },
  "subject": {
    "reference": "Patient/example"
  },
  "valueQuantity": {
    "value": 67,
    "unit": "kg",
    "system": "http://unitsofmeasure.org",
    "code": "kg"
  }
}

### Validate System-level - Any Resource Type
POST {{hostname}}/$validate
Content-Type: application/fhir+json
Prefer: validation=minimum

{
  "resourceType": "Encounter",
  "status": "planned",
  "class": {
    "system": "http://terminology.hl7.org/CodeSystem/v3-ActCode",
    "code": "AMB"
  },
  "subject": {
    "reference": "Patient/example"
  }
}

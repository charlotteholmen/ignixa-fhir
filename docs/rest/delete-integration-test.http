###
# DELETE Integration Test
# Tests FHIR R4 DELETE specification compliance
###

### 1. PUT - Create a test Patient resource
# Expected: 201 Created (or 200 OK if already exists)
PUT http://localhost:5000/Patient/delete-test-123
Content-Type: application/fhir+json

{
  "resourceType": "Patient",
  "id": "delete-test-123",
  "name": [
    {
      "given": ["Delete"],
      "family": "Test"
    }
  ],
  "gender": "male",
  "birthDate": "1990-01-01"
}

### 2. GET - Verify resource exists before deletion
# Expected: 200 OK with full Patient resource
GET http://localhost:5000/Patient/delete-test-123
Accept: application/fhir+json

### 3. DELETE - Soft delete the resource
# Expected: 204 No Content (FHIR R4 spec)
DELETE http://localhost:5000/Patient/delete-test-123

### 4. GET - Verify resource returns 410 Gone after deletion
# Expected: 410 Gone (not 404 Not Found)
# 410 Gone = resource existed but has been deleted
# 404 Not Found = resource never existed
GET http://localhost:5000/Patient/delete-test-123
Accept: application/fhir+json

### 5. DELETE - Verify idempotency (delete already deleted resource)
# Expected: 204 No Content (same as first delete)
DELETE http://localhost:5000/Patient/delete-test-123

### 6. GET - Verify still returns 410 Gone after second delete
# Expected: 410 Gone
GET http://localhost:5000/Patient/delete-test-123
Accept: application/fhir+json

### 7. GET _history - Verify deletion appears in version history
# Expected: Bundle with entry for deleted version (IsDeleted=true)
GET http://localhost:5000/Patient/delete-test-123/_history
Accept: application/fhir+json

### 8. DELETE non-existent resource
# Expected: 404 Not Found (resource never existed)
DELETE http://localhost:5000/Patient/never-existed-resource

### 9. Multi-tenant test - DELETE with explicit tenant
# Expected: 204 No Content
PUT http://localhost:5000/tenant/1/Patient/tenant-delete-test-456
Content-Type: application/fhir+json

{
  "resourceType": "Patient",
  "id": "tenant-delete-test-456",
  "name": [
    {
      "given": ["Tenant"],
      "family": "Delete Test"
    }
  ]
}

###
DELETE http://localhost:5000/tenant/1/Patient/tenant-delete-test-456

###
GET http://localhost:5000/tenant/1/Patient/tenant-delete-test-456
Accept: application/fhir+json

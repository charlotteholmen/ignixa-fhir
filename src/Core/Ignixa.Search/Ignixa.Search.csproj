<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <!-- Suppress CLS-compliance warnings for interfaces from Ignixa.Domain -->
    <NoWarn>$(NoWarn);CS3001;CS3002;CS3003;CS3009;CS3027</NoWarn>
  </PropertyGroup>

  <!-- NuGet Package Configuration -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageStability>stable</PackageStability>
    <Description>FHIR search parameter indexing and query infrastructure</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Ignixa.FhirPath\Ignixa.FhirPath.csproj" />
    <ProjectReference Include="..\Ignixa.Specification\Ignixa.Specification.csproj" />
    <ProjectReference Include="..\Ignixa.Serialization\Ignixa.Serialization.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Models" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" />
    <PackageReference Include="NuGet.Versioning" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Data\R4\BaseCapabilities.json" />
    <None Remove="Data\R4\unsupported-search-parameters.json" />
    <None Remove="Data\R5\BaseCapabilities.json" />
    <None Remove="Data\R5\unsupported-search-parameters.json" />
    <None Remove="Data\Stu3\BaseCapabilities.json" />
    <None Remove="Data\Stu3\unsupported-search-parameters.json" />
    <None Remove="Data\R4B\BaseCapabilities.json" />
    <None Remove="Data\R4B\unsupported-search-parameters.json" />
  </ItemGroup>

</Project>


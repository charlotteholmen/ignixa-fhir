<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- NuGet Package Configuration -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Ignixa.FhirFakes</PackageId>
    <Version>0.1.0-preview</Version>
    <Description>A comprehensive FHIR test data generation library for modeling patient populations and medical histories.</Description>
    <PackageTags>$(PackageTags);test-data;test-generation;fake-data;bogus;demographics</PackageTags>
    <!-- TODO: Enable after fixing XML documentation errors (CS1570) -->
    <!-- <GenerateDocumentationFile>true</GenerateDocumentationFile> -->
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Ignixa.FhirFakes.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Bogus" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Ignixa.Specification\Ignixa.Specification.csproj" />
    <ProjectReference Include="..\Ignixa.Serialization\Ignixa.Serialization.csproj" />
  </ItemGroup>

</Project>


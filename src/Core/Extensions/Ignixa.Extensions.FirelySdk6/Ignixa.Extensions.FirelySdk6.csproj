<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Ignixa.Extensions.FirelySdk</RootNamespace>
  </PropertyGroup>

  <!-- NuGet Package Configuration -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageStability>stable</PackageStability>
    <Description>Firely SDK interoperability shims for bidirectional conversion</Description>
    <PackageTags>FHIR;HL7;Healthcare;Firely;Interop;Adapter</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Ignixa abstractions with new interfaces -->
    <ProjectReference Include="..\..\Ignixa.Abstractions\Ignixa.Abstractions.csproj" />
    <!-- Ignixa serialization for SchemaAwareElement (ISourceNavigator → IElement) -->
    <ProjectReference Include="..\..\Ignixa.Serialization\Ignixa.Serialization.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Firely SDK base package for ITypedElement, ISourceNode, IElementDefinitionSummary -->
    <PackageReference Include="Hl7.Fhir.Base" />
  </ItemGroup>
</Project>


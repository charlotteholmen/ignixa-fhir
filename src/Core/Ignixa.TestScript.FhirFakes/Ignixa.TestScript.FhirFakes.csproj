    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageStability>beta</PackageStability>
    <PackageId>Ignixa.TestScript.FhirFakes</PackageId>

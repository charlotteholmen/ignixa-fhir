{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
       "Microsoft.EntityFrameworkCore.Database.Command": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Ignixa": "Debug"
    }
  },
  "AllowedHosts": "*",
  "FhirRepository": {
    "BaseDirectory": "fhir-data"
  },
  "LocalFileBlobStorage": {
    "RootDirectory": "fhir-exports"
  },
  "Tenants": {
    "_Comment_Mode": "Controls multi-tenancy behavior. 'Isolated' = multiple customers with separate data stores (SaaS). 'Distributed' = single customer with horizontal sharding (NOT YET IMPLEMENTED - Phase 20.2+)",
    "Mode": "Isolated",
    "_Comment_Configurations": "Array of tenant configurations. TenantId 0 is RESERVED for system operations (transaction IDs). Regular tenants start at TenantId 1+",
    "Configurations": [
        {
            "_Comment": "System Partition - Reserved for transaction IDs",
            "TenantId": 0,
            "DisplayName": "System Partition (Reserved)",
            "FhirVersion": "4.0",
            "IsActive": true,
            "IsSystemPartition": true,
            "Storage": {
                "Type": "FileSystem",
                "BaseDirectory": "system"
            }
        },
        {
            "_Comment": "Tenant 1 - FileSystem Storage",
            "TenantId": 1,
            "DisplayName": "FileSystem Clinic",
            "FhirVersion": "4.3",
            "IsActive": false,
            "Storage": {
                "Type": "FileSystem",
                "BaseDirectory": "tenants/1"
            }
        },
        {
            "_Comment": "Tenant 2 - SQL Server Storage (Legacy Schema)",
            "TenantId": 2,
            "DisplayName": "SQL Server Clinic",
            "FhirVersion": "4.0",
            "IsActive": true,
            "Storage": {
                "Type": "SqlEntityFramework",
                "ConnectionString": "server=(local);Initial Catalog=FHIR_R4;Integrated Security=true;TrustServerCertificate=true"
            }
        },
        {
            "_Comment": "Tenant 3 - STU3 Test Clinic",
            "TenantId": 3,
            "DisplayName": "STU3 Test Clinic",
            "FhirVersion": "3.0.2",
            "IsActive": false,
            "Storage": {
                "Type": "FileSystem",
                "BaseDirectory": "tenants/3"
            }
        }
    ]
  },
  "TransactionWatcher": {
    "_Comment": "Automatically commits stalled transactions. Scans all active tenants periodically.",
    "Enabled": true,
    "ScanInterval": "00:01:00",
    "StallThreshold": "00:05:00"
  }
}

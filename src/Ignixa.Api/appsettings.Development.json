{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Ignixa": "Trace",
      "Ignixa.Api.Middleware.TenantResolutionMiddleware": "Debug",
      "Ignixa.Application.Infrastructure": "Debug"
    }
  },
  "FhirRepository": {
    "BaseDirectory": "fhir-data"
  }, 
  "Tenants": {
        "_Comment_Mode": "Controls multi-tenancy behavior. 'Isolated' = multiple customers with separate data stores (SaaS). 'Distributed' = single customer with horizontal sharding (NOT YET IMPLEMENTED - Phase 20.2+)",
        "Mode": "Isolated",
        "_Comment_Configurations": "Array of tenant configurations. TenantId 0 is RESERVED for system operations (transaction IDs). Regular tenants start at TenantId 1+",
        "Configurations": [
            {
                "_Comment": "System Partition - Reserved for transaction IDs",
                "TenantId": 0,
                "DisplayName": "System Partition (Reserved)",
                "FhirVersion": "4.0",
                "IsActive": true,
                "IsSystemPartition": true,
                "Storage": {
                    "Type": "FileSystem",
                    "BaseDirectory": "system"
                }
            },
            {
                "_Comment": "Tenant 1 - SQL Server Storage (MS Health Schema)",
                "TenantId": 1,
                "DisplayName": "MS Health SQL Server Clinic",
                "FhirVersion": "4.0",
                "IsActive": true,
                "Storage": {
                    "Type": "SqlEntityFramework",
                    "ConnectionString": "server=(local);Initial Catalog=FHIR_R4;Integrated Security=true;TrustServerCertificate=true"
                }
            }
        ]
    }
}

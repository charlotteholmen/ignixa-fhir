{
  "OpenIddict": {
    "Enabled": true,
    "Issuer": "https://localhost:5001",
    "Audience": "fhir-api",
    "UseInMemoryStorage": true,
    "DisableHttpsRequirement": true,
    "DisableAccessTokenEncryption": true,
    "ClientApplications": [
      {
        "ClientId": "fhir-client",
        "ClientSecret": "fhir-secret-change-in-production",
        "DisplayName": "FHIR Test Client",
        "GrantTypes": [ "client_credentials" ],
        "Scopes": [
          "system/*.read",
          "system/*.write",
          "system/Patient.read",
          "system/Observation.read"
        ],
        "IsPublicClient": false,
        "Roles": [ "SystemAdmin" ]
      },
      {
        "ClientId": "smart-app",
        "ClientSecret": "smart-secret-change-in-production",
        "DisplayName": "SMART on FHIR App",
        "RedirectUris": [ "https://localhost:3000/callback" ],
        "PostLogoutRedirectUris": [ "https://localhost:3000/" ],
        "GrantTypes": [ "authorization_code", "refresh_token" ],
        "Scopes": [
          "openid",
          "profile",
          "fhirUser",
          "launch",
          "offline_access",
          "patient/*.read",
          "user/*.read"
        ],
        "IsPublicClient": false,
        "Roles": [ "Practitioner" ]
      },
      {
        "ClientId": "postman-client",
        "DisplayName": "Postman Testing Client",
        "GrantTypes": [ "password", "refresh_token" ],
        "Scopes": [
          "openid",
          "profile",
          "fhirUser",
          "offline_access",
          "user/*.read",
          "user/*.write"
        ],
        "IsPublicClient": true,
        "Roles": [ "Practitioner" ]
      }
    ],
    "DevelopmentUsers": [
      {
        "Username": "admin",
        "Password": "admin123",
        "FhirUser": "Practitioner/admin",
        "Roles": [ "SystemAdmin" ]
      },
      {
        "Username": "doctor",
        "Password": "doctor123",
        "FhirUser": "Practitioner/doctor1",
        "Roles": [ "Practitioner" ]
      },
      {
        "Username": "patient",
        "Password": "patient123",
        "PatientId": "Patient/example",
        "Roles": [ "Patient" ]
      }
    ]
  }
}

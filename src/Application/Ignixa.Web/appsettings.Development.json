{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "Ignixa": "Trace",
      "Ignixa.Api.Middleware.TenantResolutionMiddleware": "Debug",
      "Ignixa.Application.Infrastructure": "Debug",
      "Ignixa.Application.Features.Authorization": "Debug"
    }
  },
  "OpenIddict": {
    "Enabled": true,
    "UseInMemoryStorage": true,
    "DisableHttpsRequirement": true,
    "DisableAccessTokenEncryption": true,
    "ClientApplications": [
      {
        "ClientId": "fhir-admin-client",
        "ClientSecret": "dev-secret",
        "DisplayName": "Admin Client",
        "GrantTypes": ["client_credentials"],
        "Scopes": ["system/*.cruds", "system/*.rs"],
        "Roles": ["Admin"]
      },
      {
        "ClientId": "fhir-clinician-client",
        "ClientSecret": "dev-secret",
        "DisplayName": "Clinician Client",
        "GrantTypes": ["client_credentials"],
        "Scopes": ["user/Patient.rs", "user/Observation.cruds"],
        "Roles": ["Clinician"]
      },
      {
        "ClientId": "postman-client",
        "DisplayName": "Postman Testing Client",
        "GrantTypes": ["password", "refresh_token"],
        "Scopes": ["openid", "profile", "fhirUser", "offline_access", "user/*.cruds"],
        "IsPublicClient": true
      }
    ],
    "DevelopmentUsers": [
      {
        "Username": "admin",
        "Password": "admin123",
        "FhirUser": "Practitioner/admin",
        "Roles": ["Admin"]
      },
      {
        "Username": "doctor",
        "Password": "doctor123",
        "FhirUser": "Practitioner/doctor1",
        "Roles": ["Clinician"]
      }
    ]
  },
  "FhirRepository": {
    "BaseDirectory": "fhir-data"
  },
  "BlobStorage": {
    "_Comment": "Provider selection: 'Local' for filesystem, 'Azure' for Azure Blob Storage",
    "Provider": "Azure"
  },
  "LocalFileBlobStorage": {
    "_Comment": "Local filesystem blob storage configuration. Used when BlobStorage:Provider = 'Local'",
    "RootDirectory": "fhir-exports"
  },
  "AzureBlobStorage": {
    "_Comment": "Azure Blob Storage configuration. Used when BlobStorage:Provider = 'Azure'",
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "fhir-storage",
    "UseManagedIdentity": false
  },
  "Authentication": {
    "_Comment": "OIDC discovery via Authority URL - endpoints discovered automatically from /.well-known/openid-configuration",
    "Authority": "https://localhost:7058",
    "Audience": "fhir-api"
  },
  "DurableTask": {
    "_Comment": "DurableTask orchestration backend: 'FileSystem' for dev, 'AzureStorage' for cloud",
    "Provider": "AzureStorage",
    "AzureStorage": {
      "_Comment": "Azure Storage connection for DurableTask state management. Uses Azurite emulator in dev.",
      "UseManagedIdentity": false,
      "ConnectionString": "UseDevelopmentStorage=true",
      "StorageAccountName": "",
      "TaskHubName": "ignixadev"
    }
  },
  "Authorization": {
    "_Comment": "Development authorization settings - authentication disabled for easier testing",
    "Enabled": false,
    "RequireAuthentication": false,
    "EnforceTenantIsolation": false,
    "EnforceCapabilities": true,
    "SmartOnFhir": {
      "EnableSmartConfiguration": true,
      "AuthorizeUrl": "https://localhost:7058/connect/authorize",
      "TokenUrl": "https://localhost:7058/connect/token"
    },
    "_Comment_TestUsers": "Test users for development. In production, use external IdP (Entra ID, Okta, etc.)",
    "TestUsers": [
      {
        "Username": "admin@dev.local",
        "Password": "Admin123!",
        "Roles": ["Admin"],
        "TenantId": "1"
      },
      {
        "Username": "clinician@dev.local",
        "Password": "Clinician123!",
        "Roles": ["Clinician"],
        "TenantId": "1"
      },
      {
        "Username": "readonly@dev.local",
        "Password": "ReadOnly123!",
        "Roles": ["ReadOnly"],
        "TenantId": "1"
      }
    ],
    "_Comment_TestClients": "OAuth test clients for development (OpenIddict)",
    "TestClients": [
      {
        "ClientId": "fhir-admin-client",
        "ClientSecret": "dev-secret",
        "DisplayName": "Admin Client",
        "Scopes": ["system/*.rs", "system/*.cruds"]
      },
      {
        "ClientId": "fhir-clinician-client",
        "ClientSecret": "dev-secret",
        "DisplayName": "Clinician Client",
        "Scopes": ["user/Patient.rs", "user/Observation.rs", "user/Observation.cud"]
      },
      {
        "ClientId": "fhir-patient-client",
        "ClientSecret": "dev-secret",
        "DisplayName": "Patient Client",
        "Scopes": ["patient/Observation.rs", "patient/MedicationRequest.rs"]
      },
      {
        "ClientId": "readonly-client",
        "ClientSecret": "readonly-secret",
        "DisplayName": "ReadOnly Client",
        "Scopes": ["system/*.rs"]
      }
    ]
  },
  "Tenants": {
      "_Comment_Mode": "Controls multi-tenancy behavior. 'Isolated' = multiple customers with separate data stores (SaaS). 'Distributed' = single customer with horizontal sharding (NOT YET IMPLEMENTED - Phase 20.2+)",
      "Mode": "Isolated",
      "_Comment_Configurations": "Array of tenant configurations. TenantId 0 is RESERVED for system operations (transaction IDs). Regular tenants start at TenantId 1+",
      "Configurations": [
          {
              "_Comment": "System Partition - Reserved for transaction IDs. Shares database with Tenant 1.",
              "TenantId": 0,
              "DisplayName": "System Partition (Reserved)",
              "FhirVersion": "4.0",
              "IsActive": true,
              "IsSystemPartition": true,
              "Storage": {
                  "Type": "SqlEntityFramework",
                  "InheritConnectionStringFromTenant": true,
                  "ConnectionString": null
              }
          },
          {
              "_Comment": "Tenant 1 - SQL Server Storage (MS Health Schema)",
              "TenantId": 1,
              "DisplayName": "MS Health SQL Server Clinic",
              "FhirVersion": "4.0",
              "IsActive": true,
              "Storage": {
                  "Type": "SqlEntityFramework",
                  "ConnectionString": "server=(local);Initial Catalog=FHIR_R4;Integrated Security=true;TrustServerCertificate=true"
              }
          }
      ]
  },
  "Mcp": {
    "_Comment": "Model Context Protocol (MCP) integration for AI-accessible FHIR operations. Set Enabled to false to disable MCP endpoints and services.",
    "Enabled": true
  }
}

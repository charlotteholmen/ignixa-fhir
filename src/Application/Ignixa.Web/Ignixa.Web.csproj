<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <NoWarn>$(NoWarn);NU1900</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Expose internal types (including implicit Program class) to compatibility tests -->
    <InternalsVisibleTo Include="Ignixa.Tests.Compatibility.E2E" />
    <InternalsVisibleTo Include="Ignixa.Api.E2ETests" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="fhir-data\" />
    <Folder Include="fhir-data\tenants\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Ignixa.Api\Ignixa.Api.csproj" />
  </ItemGroup>

</Project>


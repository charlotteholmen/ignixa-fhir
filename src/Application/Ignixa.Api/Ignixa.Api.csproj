<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Enable ASP.NET Core implicit usings for web types (IResult, etc.) -->
    <EnableDefaultCompileItems>true</EnableDefaultCompileItems>
    <NoWarn>$(NoWarn);NU1900</NoWarn>
    
    <!-- Enable packaging for internal GitHub Packages feed -->
    <IsPackable>true</IsPackable>
    <PackageId>Ignixa.Api</PackageId>
    <Description>FHIR API endpoints and middleware for Ignixa FHIR Server</Description>
    <PackageTags>FHIR;HL7;Healthcare;API</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reference ASP.NET Core framework for web types -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <!-- Add ASP.NET Core implicit usings -->
    <Using Include="Microsoft.AspNetCore.Builder" />
    <Using Include="Microsoft.AspNetCore.Http" />
    <Using Include="Microsoft.AspNetCore.Routing" />
    <Using Include="Microsoft.Extensions.Configuration" />
    <Using Include="Microsoft.Extensions.DependencyInjection" />
    <Using Include="Microsoft.Extensions.Hosting" />
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expose internal types to compatibility and E2E tests -->
    <InternalsVisibleTo Include="Ignixa.Tests.Compatibility.E2E" />
    <InternalsVisibleTo Include="Ignixa.Api.E2ETests" />
    <!-- Expose internal types to Ignixa.Web hosting layer -->
    <InternalsVisibleTo Include="Ignixa.Web" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core packages - versions managed in Directory.Packages.props -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Microsoft.IO.RecyclableMemoryStream" />
    <PackageReference Include="Medino" />
    <PackageReference Include="Autofac" />
    <PackageReference Include="Autofac.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Azure.DurableTask.Core" />
    <PackageReference Include="Microsoft.Azure.DurableTask.AzureStorage" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
    <PackageReference Include="Polly.Extensions.Http" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
  </ItemGroup>



  <ItemGroup>
    <ProjectReference Include="..\Ignixa.Domain\Ignixa.Domain.csproj" />
    <ProjectReference Include="..\Ignixa.Application\Ignixa.Application.csproj" />
    <ProjectReference Include="..\Ignixa.Application.Operations\Ignixa.Application.Operations.csproj" />
    <ProjectReference Include="..\Ignixa.Sidecar.Contracts\Ignixa.Sidecar.Contracts.csproj" />
    <ProjectReference Include="..\..\DataLayer\Ignixa.DataLayer.FileSystem\Ignixa.DataLayer.FileSystem.csproj" />
    <ProjectReference Include="..\..\DataLayer\Ignixa.DataLayer.BlobStorage\Ignixa.DataLayer.BlobStorage.csproj" />
    <ProjectReference Include="..\..\DataLayer\Ignixa.DataLayer.SqlEntityFramework\Ignixa.DataLayer.SqlEntityFramework.csproj" />
    <ProjectReference Include="..\..\DataLayer\Ignixa.DataLayer.InMemoryIndex\Ignixa.DataLayer.InMemoryIndex.csproj" />
    <ProjectReference Include="..\..\Core\Ignixa.Serialization\Ignixa.Serialization.csproj" />
    <ProjectReference Include="..\..\Core\Ignixa.Specification\Ignixa.Specification.csproj" />
    <ProjectReference Include="..\..\Core\Ignixa.Validation\Ignixa.Validation.csproj" />
    <ProjectReference Include="..\..\Core\Ignixa.Search\Ignixa.Search.csproj" />
    <ProjectReference Include="..\Ignixa.Application.BackgroundOperations\Ignixa.Application.BackgroundOperations.csproj" />
    <ProjectReference Include="..\..\Core\Ignixa.PackageManagement\Ignixa.PackageManagement.csproj" />
    <ProjectReference Include="..\..\Core\Ignixa.SqlOnFhir\Ignixa.SqlOnFhir.csproj" />
  </ItemGroup>

</Project>


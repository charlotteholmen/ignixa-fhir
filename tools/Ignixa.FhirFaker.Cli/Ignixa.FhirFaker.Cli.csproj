<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Ignixa.FhirFaker.Cli</RootNamespace>
    <AssemblyName>ignixa-faker</AssemblyName>
    <NoWarn>CA1303,CA1869,CA1861,CA2000,CA1031,CA1852,IDE0073,CA1307,CA1310</NoWarn>
  </PropertyGroup>

  <!-- NuGet Package & Tool Configuration -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>ignixa-faker</ToolCommandName>
    <PackageId>Ignixa.FhirFaker.Cli</PackageId>
    <Version>0.1.0-preview</Version>
    <Description>CLI tool for generating FHIR test data using the FhirFaker library. Supports single resources, scenarios, and population generation.</Description>
    <PackageTags>$(PackageTags);fhir;cli;tool;test-data;fake-data</PackageTags>
    <PackageOutputPath>./nupkg</PackageOutputPath>
  </PropertyGroup>

  <!-- Include README in NuGet package -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Core\Ignixa.FhirFakes\Ignixa.FhirFakes.csproj" />
    <ProjectReference Include="..\..\src\Core\Ignixa.Serialization\Ignixa.Serialization.csproj" />
    <ProjectReference Include="..\..\src\Core\Ignixa.Specification\Ignixa.Specification.csproj" />
  </ItemGroup>

</Project>

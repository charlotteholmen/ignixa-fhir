<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Ignixa.Validation.Cli</RootNamespace>
    <AssemblyName>ignixa-validator</AssemblyName>
    <NoWarn>CA1303,CA1869,CA1861,CA2000,CA1031,CA1852,IDE0073,CA1307,CA1310</NoWarn>
  </PropertyGroup>

  <!-- NuGet Package & Tool Configuration -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageStability>stable</PackageStability>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>ignixa-validator</ToolCommandName>
    <PackageId>Ignixa.Validation.Cli</PackageId>
    <Description>CLI tool for validating FHIR resources using the Ignixa.Validation library. Supports file input, JSON string input, and formatted console output.</Description>
    <PackageTags>$(PackageTags);fhir;cli;tool;validation;validator</PackageTags>
    <PackageOutputPath>./nupkg</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Core\Ignixa.Validation\Ignixa.Validation.csproj" />
    <ProjectReference Include="..\..\src\Core\Ignixa.Serialization\Ignixa.Serialization.csproj" />
    <ProjectReference Include="..\..\src\Core\Ignixa.Specification\Ignixa.Specification.csproj" />
    <ProjectReference Include="..\..\src\Core\Ignixa.PackageManagement\Ignixa.PackageManagement.csproj" />
  </ItemGroup>

</Project>

